        "options": {}
      },
      "id": "if-emergency",
      "name": "Emergency Alert Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 400]
    },
    {
      "parameters": {
        "from": "={{$env.ADMIN_EMAIL}}",
        "to": "={{$env.ADMIN_EMAIL}}",
        "subject": "EMERGENCY ALERT - High Priority Patient",
        "emailType": "html",
        "message": "=<h2>⚠️ EMERGENCY ALERT</h2>\n<p>A high-priority emergency case has been identified:</p>\n<h3>Patient Information:</h3>\n<ul>\n  <li><strong>Name:</strong> {{$json.patientInfo.name}}</li>\n  <li><strong>Phone:</strong> {{$json.patientInfo.phone}}</li>\n  <li><strong>Email:</strong> {{$json.patientInfo.email}}</li>\n</ul>\n<h3>Symptoms:</h3>\n<p>{{$json.symptoms.join(', ')}}</p>\n<h3>AI Analysis:</h3>\n<p>{{$json.analysis.summary}}</p>\n<p><strong>Immediate attention required!</strong></p>",
        "options": {}
      },
      "id": "email-emergency",
      "name": "Send Emergency Alert",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1050, 500],
      "credentials": {
        "smtp": {
          "id": "2",
          "name": "Gmail SMTP"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "appointments",
        "columns": {
          "mappingMode": "autoMapInputData"
        },
        "options": {}
      },
      "id": "sqlite-1",
